<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Audio Echtzeit-Feed</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-gray-50 flex flex-col items-center py-10 gap-6">

  <h1 class="text-4xl font-bold text-gray-900">Audio Echtzeit-Feed</h1>
  
  <div id="audio-container" class="w-full max-w-md flex flex-col gap-4"></div>

  <script>
    const socket = io();
    const audioContainer = document.getElementById('audio-container');

    socket.on('new-file', (data) => {
      console.log("Neue Datei empfangen:", data.name);
      
      const fileItem = document.createElement('div');
      fileItem.className = "bg-white p-4 rounded-xl shadow-md border border-gray-200";
      
      // Nutze die neue Proxy-Route /stream/
      const streamUrl = `/stream/${encodeURIComponent(data.name)}`;

      fileItem.innerHTML = `
        <p class="text-xs text-gray-500 mb-2 truncate">Datei: ${data.name}</p>
        <audio controls class="w-full">
            <source src="${streamUrl}" type="audio/wav">
            Dein Browser unterstützt kein Audio.
        </audio>
      `;

      audioContainer.prepend(fileItem);
    });
  </script>
</body>
</html>